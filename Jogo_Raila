function loadState(){
  try{
    const d=JSON.parse(localStorage.getItem('dollStudio3D')||'{}');
    if(d.dolls) G.dolls=d.dolls;
    if(d.gallery) G.gallery=d.gallery;
  }catch(e){}
}
function saveState(){
  try{localStorage.setItem('dollStudio3D',JSON.stringify({dolls:G.dolls,gallery:G.gallery}));}catch(e){}
}

/* ══════════════════════════════════════════
   NAV
══════════════════════════════════════════ */
function goTo(id){
  document.querySelectorAll('.screen').forEach(s=>{s.classList.remove('active');});
  const el=document.getElementById(id);
  if(el){el.classList.add('active');el.classList.add('fx-in');setTimeout(()=>el.classList.remove('fx-in'),400);}
  if(id==='screen-select') renderSelectCards();
  if(id==='screen-gallery') renderGallery();
}

/* ══════════════════════════════════════════
   HOME
══════════════════════════════════════════ */
function buildStars(){
  const c=document.getElementById('home-stars');
  if(!c) return;
  for(let i=0;i<60;i++){
    const s=document.createElement('div');
    s.className='star';
    const sz=1+Math.random()*3;
    s.style.cssText=`left:${Math.random()*100}%;top:${Math.random()*100}%;width:${sz}px;height:${sz}px;--d:${2+Math.random()*4}s;--dl:${Math.random()*4}s`;
    c.appendChild(s);
  }
}
function renderHomePreviews(){
  const c=document.getElementById('home-dolls-preview');
  if(!c) return;
  c.innerHTML=G.dolls.map(d=>`<div class="home-doll-wrap">${buildDoll(d,90,180)}</div>`).join('');
}

/* ══════════════════════════════════════════
   SELECT
══════════════════════════════════════════ */
function renderSelectCards(){
  for(let i=0;i<2;i++){
    const p=document.getElementById(`prev${i}`);
    if(p) p.innerHTML=buildDoll(G.dolls[i],110,220);
    const n=document.getElementById(`cname${i}`);
    if(n) n.textContent=G.dolls[i].name;
  }
}

/* ══════════════════════════════════════════
   RESET / DELETE DOLL (no SELECT)
══════════════════════════════════════════ */
function confirmResetDoll(i){
  G.resetIdx = i;
  document.getElementById('reset-msg').textContent =
    `Isso vai apagar toda a personalização da Boneca ${i+1} ("${G.dolls[i].name}") e voltar ao padrão. Tem certeza?`;
  document.getElementById('modal-reset').style.display='flex';
}
function doResetDoll(){
  if(G.resetIdx !== null){
    G.dolls[G.resetIdx] = mkDoll();
    saveState();
    renderSelectCards();
    renderHomePreviews();
    closeModal('modal-reset');
    G.resetIdx = null;
  }
}

/* ══════════════════════════════════════════
   EDITOR
══════════════════════════════════════════ */
function selectDoll(i){
  G.dollIdx=i; G.tab='hair';
  updateEdName();
  renderCanvas();
  switchTab('hair');
  goTo('screen-editor');
}
const D = ()=>G.dolls[G.dollIdx];
function updateEdName(){ document.getElementById('ed-name').textContent='✏️ '+D().name; }
function renderCanvas(){ document.getElementById('doll-canvas').innerHTML=buildDoll(D(),180,330); }

function switchTab(t){
  G.tab=t;
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.getElementById('tab-'+t).classList.add('on');
  renderCatalog();
}
function renderCatalog(){
  const d=D();
  if(G.tab==='hair') renderHairCat(d);
  else if(G.tab==='makeup') renderMakeupCat(d);
  else renderOutfitCat(d);
}
function refresh(){ renderCanvas(); renderCatalog(); renderSelectCards(); saveState(); }

function changeSkin(t){ D().skinTone=t; refresh(); }
function pickHair(id){ D().hair.id=id; refresh(); }
function pickHairColor(c){ D().hair.color=c; refresh(); }
function pickMakeup(id){
  D().makeup.id=id;
  const m=MAKEUPS.find(x=>x.id===id);
  if(m) D().makeup.color=m.colors[0];
  refresh();
}
function pickMakeupColor(c){ D().makeup.color=c; refresh(); }
function pickOutfit(id){
  D().outfit.id=id;
  const o=OUTFITS.find(x=>x.id===id);
  if(o) D().outfit.color=o.colors[0];
  refresh();
}
function pickOutfitColor(c){ D().outfit.color=c; refresh(); }

function renderHairCat(d){
  let h=`<div class="sec-title">🌸 Tom de Pele</div><div class="swatches">`;
  SKINS.forEach(t=>h+=`<div class="swatch${d.skinTone===t?' on':''}" style="background:${t}" onclick="changeSkin('${t}')"></div>`);
  h+=`</div><div class="sec-title">💇 Penteado</div><div class="item-grid">`;
  HAIRS.forEach(item=>h+=`<div class="item${d.hair.id===item.id?' on':''}" onclick="pickHair('${item.id}')">
    <div class="item-img">${miniHair(item,d.hair.color)}</div>
    <div class="item-label">${item.name}</div></div>`);
  h+=`</div>`;
  const cur=HAIRS.find(x=>x.id===d.hair.id);
  if(cur){
    h+=`<div class="sec-title">🎨 Cor do Cabelo</div><div class="swatches">`;
    cur.colors.forEach(c=>h+=`<div class="swatch${d.hair.color===c?' on':''}" style="background:${c}" onclick="pickHairColor('${c}')"></div>`);
    h+=`</div>`;
  }
  document.getElementById('catalog').innerHTML=h;
}

function renderMakeupCat(d){
  let h=`<div class="sec-title">💄 Estilo de Maquiagem</div><div class="item-grid">`;
  MAKEUPS.forEach(item=>h+=`<div class="item${d.makeup.id===item.id?' on':''}" onclick="pickMakeup('${item.id}')">
    <div class="item-img">${miniMakeup(item,d.makeup.color,d.skinTone)}</div>
    <div class="item-label">${item.name}</div></div>`);
  h+=`</div>`;
  if(d.makeup.id!=='m0'){
    const cur=MAKEUPS.find(x=>x.id===d.makeup.id);
    if(cur){
      h+=`<div class="sec-title">🎨 Cor da Maquiagem</div><div class="swatches">`;
      cur.colors.forEach(c=>h+=`<div class="swatch${d.makeup.color===c?' on':''}" style="background:${c}" onclick="pickMakeupColor('${c}')"></div>`);
      h+=`</div>`;
    }
  }
  document.getElementById('catalog').innerHTML=h;
}

function renderOutfitCat(d){
  let h=`<div class="sec-title">👗 Roupa</div><div class="item-grid">`;
  OUTFITS.forEach(item=>h+=`<div class="item${d.outfit.id===item.id?' on':''}" onclick="pickOutfit('${item.id}')">
    <div class="item-img">${miniOutfit(item,d.outfit.color)}</div>
    <div class="item-label">${item.name}</div></div>`);
  h+=`</div>`;
  const cur=OUTFITS.find(x=>x.id===d.outfit.id);
  if(cur){
    h+=`<div class="sec-title">🎨 Cor da Roupa</div><div class="swatches">`;
    cur.colors.forEach(c=>h+=`<div class="swatch${d.outfit.color===c?' on':''}" style="background:${c}" onclick="pickOutfitColor('${c}')"></div>`);
    h+=`</div>`;
  }
  document.getElementById('catalog').innerHTML=h;
}

/* ══════════════════════════════════════════
   NOME
══════════════════════════════════════════ */
function openNameModal(){
  const inp=document.getElementById('name-input');
  inp.value=D().name==='Sem nome'?'':D().name;
  document.getElementById('modal-name').style.display='flex';
  setTimeout(()=>inp.focus(),120);
}
function saveName(){
  const v=document.getElementById('name-input').value.trim()||'Sem nome';
  D().name=v; updateEdName(); saveState(); closeModal('modal-name');
}

/* ══════════════════════════════════════════
   SALVAR NA GALERIA
══════════════════════════════════════════ */
function saveDoll(){
  const d=D();
  if(d.name==='Sem nome'){openNameModal();return;}
  const dt=new Date().toLocaleDateString('pt-BR',{day:'2-digit',month:'short',year:'numeric'});
  G.gallery.unshift({doll:JSON.parse(JSON.stringify(d)),savedAt:dt});
  saveState();
  renderHomePreviews();
  document.getElementById('saved-msg').textContent=`"${d.name}" foi salva na galeria! 💖`;
  document.getElementById('modal-saved').style.display='flex';
  spawnHearts();
}

/* ══════════════════════════════════════════
   GALERIA
══════════════════════════════════════════ */
function renderGallery(){
  const grid=document.getElementById('gallery-grid');
  const empty=document.getElementById('gallery-empty');
  if(!G.gallery.length){
    grid.style.display='none'; empty.style.display='flex';
    const ed=document.getElementById('empty-doll');
    if(ed) ed.innerHTML=buildDoll(mkDoll(),90,180);
    return;
  }
  grid.style.display='grid'; empty.style.display='none';
  grid.innerHTML=G.gallery.map((e,i)=>`
    <div class="gallery-card" onclick="openDetail(${i})">
      <div class="gallery-thumb">${buildDoll(e.doll,90,160)}</div>
      <div class="gallery-info">
        <div class="gallery-name">${e.doll.name}</div>
        <div class="gallery-date">${e.savedAt}</div>
      </div>
    </div>`).join('');
}
function openDetail(i){
  G.galleryIdx=i;
  const e=G.gallery[i];
  document.getElementById('detail-doll').innerHTML=buildDoll(e.doll,120,220);
  document.getElementById('detail-name').textContent=e.doll.name;
  document.getElementById('detail-date').textContent='Salva em: '+e.savedAt;
  document.getElementById('modal-detail').style.display='flex';
}
function deleteDoll(){
  if(G.galleryIdx!==null){G.gallery.splice(G.galleryIdx,1);saveState();closeModal('modal-detail');renderGallery();}
}
function closeModal(id){document.getElementById(id).style.display='none';}

/* ══════════════════════════════════════════
   EFEITOS
══════════════════════════════════════════ */
function spawnHearts(){
  const opts=['💖','💕','💗','🌸','✨','⭐','🎀'];
  for(let i=0;i<14;i++){
    setTimeout(()=>{
      const h=document.createElement('div');
      h.className='float-heart';
      h.textContent=opts[~~(Math.random()*opts.length)];
      h.style.left=(15+Math.random()*70)+'%';
      h.style.bottom='120px';
      document.body.appendChild(h);
      setTimeout(()=>h.remove(),2100);
    },i*100);
  }
}
</script>
