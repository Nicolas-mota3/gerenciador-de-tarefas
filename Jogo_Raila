<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<title>✨ Studio Girassol✨</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
:root{
  --rose:#ff4d8f;--rose2:#ff1a6e;--rose3:#ff80b3;--rose4:#ffe0ee;
  --violet:#a259ff;--violet2:#7c3aed;--violet3:#c4b5fd;--violet4:#f3eeff;
  --gold:#ffd700;--gold2:#ffb800;
  --deep:#1e0033;--deep2:#2d0050;--deep3:#3d006e;
  --card:#fff;--card2:rgba(255,255,255,.97);
  --text:#2d0050;--text2:#7a4a9a;--text3:#bfa0cf;
  --shadow:0 8px 40px rgba(162,89,255,.18);
  --shadow2:0 2px 16px rgba(255,77,143,.15);
  --r:20px;--r2:28px;--r3:50px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{width:100%;height:100%;overflow:hidden;font-family:'Poppins',sans-serif;background:var(--deep)}
.screen{position:fixed;inset:0;display:none;overflow:hidden}
.screen.active{display:flex;flex-direction:column}
.fx-in{animation:fxIn .38s cubic-bezier(.22,1,.36,1)}
@keyframes fxIn{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}

/* HOME */
#screen-home{background:radial-gradient(ellipse at 60% 20%,#6b00b8 0%,var(--deep2) 50%,var(--deep) 100%);align-items:center;justify-content:center;}
.home-stars{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.star{position:absolute;border-radius:50%;background:white;animation:pulse var(--d,3s) var(--dl,0s) ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:.1;transform:scale(.6)}50%{opacity:.9;transform:scale(1.2)}}
.home-content{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:22px;padding:32px 24px;text-align:center;max-width:400px;width:100%}
.logo-badge{background:linear-gradient(135deg,var(--rose),var(--violet));border-radius:24px;padding:18px 32px;box-shadow:0 8px 40px rgba(162,89,255,.5),0 0 0 1px rgba(255,255,255,.15)}
.logo-title{font-family:'Playfair Display',serif;font-size:2.8rem;font-weight:900;color:#fff;text-shadow:0 2px 24px rgba(255,77,143,.6);line-height:1.1;letter-spacing:-1px}
.logo-sub{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.75);letter-spacing:2px;text-transform:uppercase;margin-top:6px}
.home-dolls{display:flex;gap:20px;align-items:flex-end;justify-content:center;filter:drop-shadow(0 12px 32px rgba(255,77,143,.4))}
.home-doll-wrap{animation:floatD 3.5s ease-in-out infinite}
.home-doll-wrap:nth-child(2){animation-delay:1.75s}

/* BUTTONS */
.btn{font-family:'Poppins',sans-serif;cursor:pointer;border:none;transition:transform .15s,box-shadow .15s;touch-action:manipulation}
.btn:active{transform:scale(.95)}
.btn-main{background:linear-gradient(135deg,var(--rose),var(--violet));color:#fff;border-radius:var(--r3);padding:15px 40px;font-size:1rem;font-weight:700;box-shadow:0 8px 32px rgba(255,77,143,.45),inset 0 1px 0 rgba(255,255,255,.25);letter-spacing:.3px;width:100%;max-width:280px}
.btn-outline{background:rgba(255,255,255,.1);color:#fff;border:1.5px solid rgba(255,255,255,.3);border-radius:var(--r3);padding:13px 36px;font-size:.95rem;font-weight:600;backdrop-filter:blur(8px);width:100%;max-width:280px}
.btn-back{background:rgba(255,255,255,.95);border-radius:50%;width:42px;height:42px;font-size:1.3rem;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:var(--deep2);font-weight:800;box-shadow:var(--shadow2)}
.btn-save{background:linear-gradient(135deg,#f8f8ff,#ffe8f4);border-radius:var(--r3);padding:10px 20px;font-size:.8rem;font-weight:700;color:var(--violet2);box-shadow:var(--shadow2);letter-spacing:.2px}
.btn-del{background:linear-gradient(135deg,#ff5252,#c62828);color:#fff;border-radius:var(--r3);padding:12px 24px;font-size:.9rem;font-weight:700;box-shadow:0 4px 16px rgba(198,40,40,.3)}
.btn-ok{background:linear-gradient(135deg,var(--rose),var(--violet));color:#fff;border-radius:var(--r3);padding:13px 32px;font-size:.95rem;font-weight:700;box-shadow:0 6px 24px rgba(255,77,143,.35)}
.btn-cancel{background:var(--violet4);color:var(--violet2);border-radius:var(--r3);padding:12px 24px;font-size:.9rem;font-weight:600}
.btn-reset{background:linear-gradient(135deg,#ff5252,#c62828);color:#fff;border-radius:var(--r3);padding:9px 16px;font-size:.75rem;font-weight:700;box-shadow:0 3px 12px rgba(198,40,40,.3);letter-spacing:.2px}

/* HEADER */
.screen-header{display:flex;align-items:center;gap:14px;padding:14px 16px 10px;background:rgba(255,255,255,.97);border-bottom:1px solid rgba(162,89,255,.12);box-shadow:0 2px 12px rgba(45,0,80,.06);flex-shrink:0;z-index:10}
.screen-header h2{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--text);flex:1}

/* SELECT */
#screen-select{background:linear-gradient(160deg,#fff5fb 0%,#f5eeff 100%)}
.select-grid{flex:1;display:flex;align-items:center;justify-content:center;gap:20px;padding:24px;flex-wrap:wrap}
.doll-card{background:var(--card);border-radius:var(--r2);padding:22px 16px 18px;box-shadow:0 8px 40px rgba(162,89,255,.15),0 0 0 3px rgba(255,128,179,.3);cursor:pointer;transition:transform .22s,box-shadow .22s;min-width:145px;flex:1;max-width:200px;position:relative}
.doll-card:hover,.doll-card:active{transform:translateY(-4px) scale(1.02);box-shadow:0 16px 48px rgba(162,89,255,.28),0 0 0 3px var(--rose)}
.doll-card-inner{display:flex;flex-direction:column;align-items:center;gap:12px}
.doll-preview-area{min-height:220px;display:flex;align-items:center;justify-content:center}
.doll-card-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--text3)}
.doll-card-name{font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--text);text-align:center;font-weight:700}
/* botão deletar no card */
.doll-card-del{position:absolute;top:10px;right:10px;background:rgba(255,82,82,.12);border:1.5px solid rgba(255,82,82,.3);color:#c62828;border-radius:50%;width:30px;height:30px;font-size:.9rem;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .2s,transform .15s;z-index:5}
.doll-card-del:hover{background:rgba(255,82,82,.25);transform:scale(1.1)}

/* EDITOR */
#screen-editor{background:linear-gradient(160deg,#fff5fb,#f5eeff)}
.editor-layout{display:flex;flex-direction:column;height:100%}
.editor-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px 10px;background:rgba(255,255,255,.97);box-shadow:0 2px 14px rgba(45,0,80,.08);flex-shrink:0;z-index:5}
.editor-doll-name{font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--text);cursor:pointer;flex:1;text-align:center;padding:0 10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:700}
.stage{flex:0 0 auto;height:44%;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.stage-bg{position:absolute;inset:0;background:linear-gradient(160deg,#fce4ec 0%,#f3e5f5 55%,#ede7f6 100%)}
.stage-bg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(255,77,143,.22) 0%,transparent 65%)}
.stage-shine{position:absolute;bottom:0;left:0;right:0;height:40%;background:linear-gradient(0deg,rgba(255,255,255,.35),transparent)}
.doll-wrap{position:relative;z-index:2;animation:floatD 4s ease-in-out infinite}
@keyframes floatD{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}

/* TABS */
.tabs{display:flex;background:#fff;border-top:1px solid rgba(162,89,255,.1);border-bottom:1px solid rgba(162,89,255,.1);flex-shrink:0;padding:0 4px}
.tab{flex:1;padding:11px 4px;border:none;background:transparent;font-family:'Poppins',sans-serif;font-size:.76rem;font-weight:700;color:var(--text2);cursor:pointer;transition:all .2s;border-bottom:3px solid transparent;white-space:nowrap;letter-spacing:.2px}
.tab.on{color:var(--rose2);border-bottom-color:var(--rose2);background:rgba(255,77,143,.05)}

/* CATALOG */
.catalog{flex:1;overflow-y:auto;padding:14px;-webkit-overflow-scrolling:touch;background:linear-gradient(160deg,#fff8fc,#f5eeff)}
.sec-title{font-size:.73rem;font-weight:700;color:var(--text2);margin-bottom:9px;letter-spacing:.5px;text-transform:uppercase;display:flex;align-items:center;gap:6px}
.swatches{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px}
.swatch{width:28px;height:28px;border-radius:50%;cursor:pointer;border:3px solid transparent;box-shadow:0 2px 8px rgba(0,0,0,.15);transition:transform .15s,border-color .15s;flex-shrink:0}
.swatch.on{border-color:var(--rose2);transform:scale(1.18);box-shadow:0 3px 14px rgba(255,77,143,.45)}
.item-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
.item{background:var(--card);border-radius:16px;padding:10px 6px 8px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:6px;border:2.5px solid transparent;box-shadow:0 2px 12px rgba(0,0,0,.06);transition:transform .15s,border-color .15s,box-shadow .15s}
.item:active{transform:scale(.93)}
.item.on{border-color:var(--rose2);box-shadow:0 4px 20px rgba(255,77,143,.28);background:#fff5f9}
.item-img{width:64px;height:64px;display:flex;align-items:center;justify-content:center}
.item-label{font-size:.65rem;font-weight:700;color:var(--text2);text-align:center;line-height:1.3}

/* GALLERY */
#screen-gallery{background:linear-gradient(160deg,#fff5fb,#f5eeff)}
.gallery-grid{flex:1;display:grid;grid-template-columns:repeat(2,1fr);gap:14px;padding:16px;overflow-y:auto;-webkit-overflow-scrolling:touch}
.gallery-card{background:var(--card);border-radius:var(--r);overflow:hidden;cursor:pointer;box-shadow:0 4px 24px rgba(162,89,255,.12);transition:transform .15s;border:1.5px solid rgba(162,89,255,.1)}
.gallery-card:active{transform:scale(.96)}
.gallery-thumb{display:flex;align-items:center;justify-content:center;padding:14px;background:linear-gradient(135deg,#fce4ec,#f3e5f5)}
.gallery-info{padding:8px 10px 10px;border-top:1px solid rgba(162,89,255,.1)}
.gallery-name{font-family:'Playfair Display',serif;font-size:.9rem;color:var(--text);font-weight:700}
.gallery-date{font-size:.62rem;color:var(--text3);margin-top:2px;font-weight:500}
.gallery-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:40px 24px;text-align:center}
.empty-doll{animation:floatD 3s ease-in-out infinite}
.gallery-empty p{font-size:.95rem;color:var(--text2);font-weight:500}

/* MODALS */
.overlay{position:fixed;inset:0;background:rgba(30,0,51,.6);display:flex;align-items:center;justify-content:center;z-index:999;padding:20px;backdrop-filter:blur(6px)}
.modal{background:#fff;border-radius:var(--r2);padding:30px 24px 24px;width:100%;max-width:320px;box-shadow:0 20px 60px rgba(45,0,80,.35);display:flex;flex-direction:column;gap:18px;align-items:center;animation:popIn .3s cubic-bezier(.34,1.56,.64,1)}
@keyframes popIn{from{transform:scale(.7);opacity:0}to{transform:scale(1);opacity:1}}
.modal h3{font-family:'Playfair Display',serif;font-size:1.3rem;color:var(--text);text-align:center;font-weight:700}
.modal input[type=text]{width:100%;border:2px solid var(--rose3);border-radius:14px;padding:13px 16px;font-family:'Poppins',sans-serif;font-size:.95rem;font-weight:500;color:var(--text);outline:none;transition:border-color .2s}
.modal input[type=text]:focus{border-color:var(--rose2)}
.modal-row{display:flex;gap:12px;width:100%;justify-content:center}
.modal-doll{display:flex;align-items:center;justify-content:center;padding:8px}
.success-icon{font-size:3.5rem;animation:bounceIcon .6s ease}
@keyframes bounceIcon{0%{transform:scale(.5)}60%{transform:scale(1.25)}100%{transform:scale(1)}}
.modal p{font-size:.9rem;color:var(--text2);font-weight:500;text-align:center;line-height:1.6}
.float-heart{position:fixed;pointer-events:none;font-size:1.5rem;z-index:9999;animation:flyHeart 2s ease-out forwards}
@keyframes flyHeart{0%{transform:translateY(0) scale(.7) rotate(-10deg);opacity:1}100%{transform:translateY(-300px) scale(1.3) rotate(15deg);opacity:0}}

/* Modal de confirmação de reset */
.modal-warn{color:#c62828;font-size:2.5rem}

::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-thumb{background:var(--rose3);border-radius:4px}
@media(min-width:480px){.item-grid{grid-template-columns:repeat(4,1fr)}.gallery-grid{grid-template-columns:repeat(3,1fr)}}
</style>
</head>
<body>

<!-- HOME -->
<div id="screen-home" class="screen active">
  <div class="home-stars" id="home-stars"></div>
  <div class="home-content fx-in">
    <div class="logo-badge">
      <div class="logo-title">✨ Studio Girassol ✨</div>
      <div class="logo-sub">Crie • Estilize • Brilhe</div>
    </div>
    <div class="home-dolls" id="home-dolls-preview"></div>
    <button class="btn btn-main" onclick="goTo('screen-select')">🎀 Jogar Agora</button>
    <button class="btn btn-outline" onclick="goTo('screen-gallery')">📸 Minha Galeria</button>
  </div>
</div>

<!-- SELECT -->
<div id="screen-select" class="screen">
  <div class="screen-header">
    <button class="btn btn-back" onclick="goTo('screen-home')">←</button>
    <h2>✨ Escolha sua Boneca</h2>
  </div>
  <div class="select-grid">
    <div class="doll-card" onclick="selectDoll(0)">
      <!-- Botão deletar boneca 0 -->
      <button class="doll-card-del btn" onclick="event.stopPropagation();confirmResetDoll(0)" title="Resetar Boneca 1">🗑️</button>
      <div class="doll-card-inner">
        <div class="doll-preview-area" id="prev0"></div>
        <div class="doll-card-label">Boneca 1</div>
        <div class="doll-card-name" id="cname0">Sem nome</div>
      </div>
    </div>
    <div class="doll-card" onclick="selectDoll(1)">
      <!-- Botão deletar boneca 1 -->
      <button class="doll-card-del btn" onclick="event.stopPropagation();confirmResetDoll(1)" title="Resetar Boneca 2">🗑️</button>
      <div class="doll-card-inner">
        <div class="doll-preview-area" id="prev1"></div>
        <div class="doll-card-label">Boneca 2</div>
        <div class="doll-card-name" id="cname1">Sem nome</div>
      </div>
    </div>
  </div>
</div>

<!-- EDITOR -->
<div id="screen-editor" class="screen">
  <div class="editor-layout">
    <div class="editor-header">
      <button class="btn btn-back" onclick="goTo('screen-select')">←</button>
      <div class="editor-doll-name" id="ed-name" onclick="openNameModal()">✏️ Sem nome</div>
      <button class="btn btn-save" onclick="saveDoll()">💾 Salvar</button>
    </div>
    <div class="stage">
      <div class="stage-bg"></div>
      <div class="stage-shine"></div>
      <div class="doll-wrap" id="doll-canvas"></div>
    </div>
    <div class="tabs">
      <button class="tab on" onclick="switchTab('hair')" id="tab-hair">💇 Cabelo</button>
      <button class="tab" onclick="switchTab('makeup')" id="tab-makeup">💄 Maquiagem</button>
      <button class="tab" onclick="switchTab('outfit')" id="tab-outfit">👗 Roupa</button>
    </div>
    <div class="catalog" id="catalog"></div>
  </div>
</div>

<!-- GALLERY -->
<div id="screen-gallery" class="screen">
  <div class="screen-header">
    <button class="btn btn-back" onclick="goTo('screen-home')">←</button>
    <h2>📸 Galeria de Bonecas</h2>
  </div>
  <div class="gallery-grid" id="gallery-grid"></div>
  <div class="gallery-empty" id="gallery-empty" style="display:none">
    <div class="empty-doll" id="empty-doll"></div>
    <p>Sua galeria está vazia!<br>Crie e salve sua primeira boneca.</p>
    <button class="btn btn-main" onclick="goTo('screen-select')">Criar Boneca</button>
  </div>
</div>

<!-- MODAL: NOME -->
<div id="modal-name" class="overlay" style="display:none">
  <div class="modal">
    <h3>✏️ Nome da Boneca</h3>
    <input type="text" id="name-input" placeholder="Ex: Luna, Sofia, Mia..." maxlength="18"/>
    <div class="modal-row">
      <button class="btn btn-cancel" onclick="closeModal('modal-name')">Cancelar</button>
      <button class="btn btn-ok" onclick="saveName()">Salvar ✓</button>
    </div>
  </div>
</div>

<!-- MODAL: SALVO -->
<div id="modal-saved" class="overlay" style="display:none">
  <div class="modal">
    <div class="success-icon">🎉</div>
    <h3>Boneca Salva!</h3>
    <p id="saved-msg">foi salva com sucesso!</p>
    <button class="btn btn-ok" onclick="closeModal('modal-saved')">Incrível! 💖</button>
  </div>
</div>

<!-- MODAL: DETALHE GALERIA -->
<div id="modal-detail" class="overlay" style="display:none">
  <div class="modal">
    <div class="modal-doll" id="detail-doll"></div>
    <h3 id="detail-name"></h3>
    <p id="detail-date"></p>
    <div class="modal-row">
      <button class="btn btn-del" onclick="deleteDoll()">🗑️ Excluir</button>
      <button class="btn btn-ok" onclick="closeModal('modal-detail')">Fechar</button>
    </div>
  </div>
</div>

<!-- MODAL: CONFIRMAR RESET BONECA -->
<div id="modal-reset" class="overlay" style="display:none">
  <div class="modal">
    <div class="modal-warn">⚠️</div>
    <h3>Deletar Criação?</h3>
    <p id="reset-msg">Isso vai apagar toda a personalização desta boneca e voltar ao padrão. Tem certeza?</p>
    <div class="modal-row">
      <button class="btn btn-cancel" onclick="closeModal('modal-reset')">Cancelar</button>
      <button class="btn btn-del" onclick="doResetDoll()">🗑️ Deletar</button>
    </div>
  </div>
</div>

<script>
/* ══════════════════════════════════════════
   UTILS
══════════════════════════════════════════ */
function shade(hex, amt){
  if(!hex||hex[0]!=='#'||hex.length<7) return hex||'#888';
  let r=parseInt(hex.slice(1,3),16), g=parseInt(hex.slice(3,5),16), b=parseInt(hex.slice(5,7),16);
  r=Math.max(0,Math.min(255,r+amt)); g=Math.max(0,Math.min(255,g+amt)); b=Math.max(0,Math.min(255,b+amt));
  return '#'+((1<<24)|(r<<16)|(g<<8)|b).toString(16).slice(1);
}
let _uid = 0;
function uid(){ return 'u'+(++_uid); }

/* ══════════════════════════════════════════
   DATA: CABELOS
══════════════════════════════════════════ */
const HAIRS = [
  {
    id:'h1', name:'Liso Longo',
    colors:['#1a0800','#5c2c0a','#9b5e1f','#d4a855','#f0d090','#1a1a1a','#e91e8c','#5e17eb','#00acc1'],
    drawBack:(c,s,id)=>`<g>
      <ellipse cx="50" cy="24" rx="28" ry="29" fill="${s(c,-30)}"/>
      <rect x="21" y="18" width="14" height="95" rx="7" fill="${s(c,-20)}"/>
      <rect x="65" y="18" width="14" height="95" rx="7" fill="${s(c,-20)}"/>
      <ellipse cx="28" cy="68" rx="7" ry="38" fill="${s(c,-35)}" opacity=".4"/>
      <ellipse cx="72" cy="68" rx="7" ry="38" fill="${s(c,-35)}" opacity=".4"/>
    </g>`,
    drawFront:(c,s,id)=>`<g>
      <ellipse cx="50" cy="23" rx="26" ry="19" fill="${c}"/>
      <ellipse cx="25" cy="34" rx="6" ry="12" fill="${c}"/>
      <ellipse cx="75" cy="34" rx="6" ry="12" fill="${c}"/>
      <ellipse cx="44" cy="15" rx="10" ry="5" fill="${s(c,28)}" opacity=".38"/>
      <ellipse cx="38" cy="13" rx="5" ry="3" fill="${s(c,35)}" opacity=".22"/>
    </g>`
  },
  {
    id:'h3', name:'Bob Curto',
    colors:['#1a0800','#5c2c0a','#9b5e1f','#1a1a1a','#e91e8c','#5e17eb','#ff5722','#4caf50','#9c27b0'],
    drawBack:(c,s,id)=>`<g>
      <ellipse cx="50" cy="24" rx="28" ry="26" fill="${s(c,-22)}"/>
      <rect x="21" y="18" width="13" height="32" rx="6.5" fill="${s(c,-15)}"/>
      <rect x="66" y="18" width="13" height="32" rx="6.5" fill="${s(c,-15)}"/>
      <ellipse cx="50" cy="48" rx="27" ry="8" fill="${s(c,-18)}"/>
    </g>`,
    drawFront:(c,s,id)=>`<g>
      <ellipse cx="50" cy="23" rx="26" ry="18" fill="${c}"/>
      <ellipse cx="25" cy="34" rx="6" ry="10" fill="${c}"/>
      <ellipse cx="75" cy="34" rx="6" ry="10" fill="${c}"/>
      <ellipse cx="44" cy="15" rx="10" ry="5" fill="${s(c,22)}" opacity=".38"/>
    </g>`
  },
  {
    id:'h4', name:'Tranças',
    colors:['#1a0800','#5c2c0a','#9b5e1f','#1a1a1a','#e91e8c','#5e17eb','#00acc1','#ff9800','#f0d090'],
    drawBack:(c,s,id)=>`<g>
